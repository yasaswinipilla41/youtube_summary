# Copy this file to .env.local and fill in real values.
# NEVER put real keys here — this file is committed to git. .env.local is git-ignored.

# ── Supabase ─────────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. NEVER expose to the browser (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI providers (tried in order: Groq → OpenAI/compatible) ─────────────
# Free tier: https://console.groq.com
GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI, or any OpenAI-compatible endpoint via OPENAI_BASE_URL
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# ── YouTube Data API v3 ──────────────────────────────────────────────────
# Google Cloud Console → Credentials → API key (starts with AIza)
YOUTUBE_API_KEY=your-youtube-api-key

# ── Admin bootstrap ──────────────────────────────────────────────────────
# Comma-separated Google emails promoted to admin on login
ADMIN_EMAILS=admin@example.com

# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
